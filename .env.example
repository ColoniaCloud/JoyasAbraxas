# ── WordPress / WooCommerce ──
# URL pública del sitio WordPress (usada en frontend para imágenes)
NEXT_PUBLIC_WP_URL=https://api.joyasabraxas.com

# Credenciales de la API REST de WooCommerce (NUNCA con NEXT_PUBLIC_)
WC_CONSUMER_KEY=ck_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
WC_CONSUMER_SECRET=cs_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# (Opcional) Endpoint de autenticación JWT. Si no se define, usa /wp-json/jwt-auth/v1/token
# WP_AUTH_ENDPOINT=

# ── MercadoPago (NUNCA con NEXT_PUBLIC_) ──
# Access Token de producción — Panel MercadoPago → Tus integraciones → Credenciales
MP_ACCESS_TOKEN=APP_USR-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# ── URLs del frontend ──
# URL pública del sitio Next.js (para back_urls de MP y webhooks)
NEXT_PUBLIC_SITE_URL=https://www.joyasabraxas.com

# ── Analítica / píxeles (opcionales; si se omiten, no se cargan) ──
# Google Analytics 4 — ID de medición (formato G-XXXXXXXXXX)
NEXT_PUBLIC_GA_ID=
# Meta (Facebook/Instagram) Pixel — ID numérico
NEXT_PUBLIC_FB_PIXEL_ID=

# ── Newsletter (opcional) ──
# Endpoint del proveedor de email marketing (Brevo/Mailchimp/Zapier…).
# Recibe POST { email, source }. Si se omite, las suscripciones NO se almacenan.
NEWSLETTER_WEBHOOK_URL=

# ── Datos de contacto (para uso futuro) ──
# WhatsApp en formato wa.me (solo dígitos, con código de país)
NEXT_PUBLIC_WHATSAPP=59898842100
# Email de contacto público
NEXT_PUBLIC_CONTACT_EMAIL=hola@joyasabraxas.com
